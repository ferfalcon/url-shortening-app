generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Link {
  id              String   @id
  originalUrl     String
  shortUrl        String
  shortCode       String
  customAlias     String?  @unique
  createdAt       DateTime @default(now())
  deletedAt       DateTime?
  createdByUserId String?
  createdByUser   User?    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdByUserId])
  @@index([deletedAt])
}

model User {
  id           String    @id
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  links        Link[]
  sessions     Session[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
