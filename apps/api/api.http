@baseUrl = http://localhost:3001
@json = application/json
@csrfCookie = shortly_csrf=replace-me
@csrfToken = replace-me
@sessionCookie = shortly_session=replace-me
@otherSessionCookie = shortly_session=replace-other-user
@ownedAlias = my-owned-alias
@ownedLinkId = replace-owned-link-id
@missingOrOtherLinkId = replace-missing-or-other-link-id

### Health check
GET {{baseUrl}}/healthz

### CSRF token
# Copy the csrfToken value from the JSON response body and the first cookie pair from
# the Set-Cookie response header, for example:
# shortly_csrf=abc123
GET {{baseUrl}}/auth/csrf

### Sign up
POST {{baseUrl}}/auth/signup
Content-Type: {{json}}
X-CSRF-Token: {{csrfToken}}
Cookie: {{csrfCookie}}

{
  "email": "user@example.com",
  "password": "password123"
}

### Log in
POST {{baseUrl}}/auth/login
Content-Type: {{json}}
X-CSRF-Token: {{csrfToken}}
Cookie: {{csrfCookie}}

{
  "email": "user@example.com",
  "password": "password123"
}

### Log in - invalid credentials
POST {{baseUrl}}/auth/login
Content-Type: {{json}}
X-CSRF-Token: {{csrfToken}}
Cookie: {{csrfCookie}}

{
  "email": "user@example.com",
  "password": "wrong-password"
}

### Current user - authenticated
# Copy only the first cookie pair from the Set-Cookie response header, for example:
# shortly_session=abc123
GET {{baseUrl}}/auth/me
Cookie: {{sessionCookie}}

### Current user - unauthenticated
GET {{baseUrl}}/auth/me

### Current user links - unauthenticated
GET {{baseUrl}}/api/links/mine

### Log out
POST {{baseUrl}}/auth/logout
X-CSRF-Token: {{csrfToken}}
Cookie: {{csrfCookie}}; {{sessionCookie}}

### Log out - invalid CSRF token
POST {{baseUrl}}/auth/logout
X-CSRF-Token: not-the-right-token
Cookie: {{csrfCookie}}; {{sessionCookie}}

### Create link - valid
POST {{baseUrl}}/api/links
Content-Type: {{json}}

{
  "originalUrl": "https://example.com/some-page"
}

### Create link - valid with custom alias
POST {{baseUrl}}/api/links
Content-Type: {{json}}

{
  "originalUrl": "https://example.com/custom",
  "customAlias": "my-alias"
}

### Create link - authenticated ownerless comparison setup
# Use the session cookie from login or sign up to create a link owned by the current user.
POST {{baseUrl}}/api/links
Content-Type: {{json}}
Cookie: {{sessionCookie}}

{
  "originalUrl": "https://example.com/account-history",
  "customAlias": "{{ownedAlias}}"
}

### Current user links - authenticated
GET {{baseUrl}}/api/links/mine
Cookie: {{sessionCookie}}

### Delete owned link - authenticated
# 1. Sign up or log in and copy the session cookie into @sessionCookie.
# 2. Create an owned link and copy its id into @ownedLinkId.
# 3. Run this request and expect 204 No Content.
DELETE {{baseUrl}}/api/links/{{ownedLinkId}}
X-CSRF-Token: {{csrfToken}}
Cookie: {{csrfCookie}}; {{sessionCookie}}

### Delete owned link - invalid CSRF token
DELETE {{baseUrl}}/api/links/{{ownedLinkId}}
X-CSRF-Token: not-the-right-token
Cookie: {{csrfCookie}}; {{sessionCookie}}

### Delete link - unauthenticated
DELETE {{baseUrl}}/api/links/{{ownedLinkId}}
X-CSRF-Token: {{csrfToken}}
Cookie: {{csrfCookie}}

### Delete link - missing or not owned
# Copy a different user's session cookie into @otherSessionCookie to verify ownership safely.
DELETE {{baseUrl}}/api/links/{{missingOrOtherLinkId}}
X-CSRF-Token: {{csrfToken}}
Cookie: {{csrfCookie}}; {{sessionCookie}}

### Delete link - other user session attempting delete
DELETE {{baseUrl}}/api/links/{{ownedLinkId}}
X-CSRF-Token: {{csrfToken}}
Cookie: {{csrfCookie}}; {{otherSessionCookie}}

### Current user links - authenticated after delete
# Run after a successful delete and confirm the deleted id no longer appears.
GET {{baseUrl}}/api/links/mine
Cookie: {{sessionCookie}}

### Ownership check flow
# 1. Sign up or log in and copy the session cookie into @sessionCookie.
# 2. Run the authenticated create-link request above.
# 3. Run Current user links - authenticated and confirm the owned link appears.
# 4. Run Delete owned link - authenticated and then Current user links - authenticated after delete.
# 5. Run Create link - valid without Cookie and confirm the anonymous link does not appear in /api/links/mine.

### Create link - invalid URL
POST {{baseUrl}}/api/links
Content-Type: {{json}}

{
  "originalUrl": "not-a-url"
}

### Create link - alias conflict (run after creating the same alias once)
POST {{baseUrl}}/api/links
Content-Type: {{json}}

{
  "originalUrl": "https://example.com/another-page",
  "customAlias": "my-alias"
}

### Create link - rate limit check
# Run this request quickly more than 5 times within one minute.
# Expect a 429 response with:
# {
#   "error": {
#     "code": "RATE_LIMITED",
#     "message": "Too many link creation requests. Please wait a minute and try again."
#   }
# }
POST {{baseUrl}}/api/links
Content-Type: {{json}}

{
  "originalUrl": "https://example.com/rate-limit-check"
}

### Create link - provider unavailable check
# Temporarily run the API with SPOO_API_BASE_URL=http://127.0.0.1:65535/api/v1
# and expect a normalized 503 response with code SHORTENING_UNAVAILABLE.
POST {{baseUrl}}/api/links
Content-Type: {{json}}

{
  "originalUrl": "https://example.com/provider-unavailable"
}

### Create link - provider timeout check
# Point SPOO_API_BASE_URL at a slow local stub and expect a normalized 503 response
# with code SHORTENING_UNAVAILABLE and a timeout-oriented message.
POST {{baseUrl}}/api/links
Content-Type: {{json}}

{
  "originalUrl": "https://example.com/provider-timeout"
}

### Create link - empty body
POST {{baseUrl}}/api/links
Content-Type: {{json}}

{}

### Create link - invalid alias characters
POST {{baseUrl}}/api/links
Content-Type: {{json}}

{
  "originalUrl": "https://example.com/test",
  "customAlias": "bad alias!"
}

### Create link - blank alias should behave as no alias
POST {{baseUrl}}/api/links
Content-Type: {{json}}

{
  "originalUrl": "https://example.com/blank-alias",
  "customAlias": ""
}
